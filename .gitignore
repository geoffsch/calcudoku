# OS cruft
.DS_Store
Thumbs.db

# Editors / IDEs
.vscode/
.idea/
*.swp

# Claude Code local config (machine-specific launch paths)
.claude/

# Node — used only for local dev tooling and tests, never shipped to the phone
node_modules/
npm-debug.log*
package-lock.json.bak

